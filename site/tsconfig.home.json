{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["vendor/memex/web/src/*"],
      "@memex/site": ["vendor/memex/web/src/site-api.ts"],
      "react": ["vendor/memex/web/node_modules/@types/react/index.d.ts"],
      "react/jsx-runtime": ["vendor/memex/web/node_modules/@types/react/jsx-runtime.d.ts"]
    }
  },
  "include": ["src/site-extension.tsx", "src/home/**/*.ts", "src/home/**/*.tsx", "src/**/*.d.ts"]
}
